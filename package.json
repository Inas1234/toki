{
  "name": "toki",
  "version": "0.1.0",
  "description": "Minimal, extensible CLI coding agent focused on automatic context efficiency.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "toki": "./dist/index.js"
  },
  "scripts": {
    "build:packages": "npm run build -w @toki/shared && npm run build -w @toki/providers && npm run build -w @toki/agent-core && npm run build -w @toki/coding-agent && npm run build -w @toki/tui",
    "dev": "npm run build:packages && tsx src/index.ts",
    "build": "npm run build:packages && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "npm run build:packages && vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@toki/agent-core": "workspace:*",
    "@toki/coding-agent": "workspace:*",
    "@toki/providers": "workspace:*",
    "@toki/shared": "workspace:*",
    "@toki/tui": "workspace:*",
    "@iarna/toml": "^2.2.5",
    "commander": "^14.0.1",
    "cosmiconfig": "^9.0.0",
    "ink": "^6.3.1",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.0",
    "tiktoken": "^1.0.22",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.2"
  }
}
